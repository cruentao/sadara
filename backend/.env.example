# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev defaults match docker-compose.yml — do NOT use these values in production
DATABASE_URL="postgresql://sadara_user:sadara_pass@localhost:5432/sadara_db?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_random_32_char_string
JWT_ACCESS_EXPIRATION=15m

# Generate with: openssl rand -hex 32  (must be different from ACCESS_SECRET)
JWT_REFRESH_SECRET=replace_with_different_random_32_char_string
JWT_REFRESH_EXPIRATION=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ─── bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
